<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hnsykrh.blooddonation.fx.LoginController"
      alignment="CENTER" spacing="12" style="-fx-padding: 24;">
    <Label text="BAXU 3113 — Blood Donation Management" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
    <Label text="Staff login"/>
    <VBox spacing="8" maxWidth="320">
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="Username:" minWidth="80"/>
            <TextField fx:id="usernameField" promptText="admin" HBox.hgrow="ALWAYS"/>
        </HBox>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="Password:" minWidth="80"/>
            <PasswordField fx:id="passwordField" promptText="password" HBox.hgrow="ALWAYS"/>
        </HBox>
    </VBox>
    <HBox spacing="10" alignment="CENTER">
        <Button text="Login" onAction="#onLogin" defaultButton="true"/>
        <Button text="Cancel" onAction="#onCancel" cancelButton="true"/>
    </HBox>
</VBox>
